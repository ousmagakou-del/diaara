<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Push Notifications capability
         "development" pour TestFlight / dev local
         "production" pour App Store release
         Apple gère automatiquement le switch entre les deux selon le build type
         tant que la clé APNs OneSignal couvre "Sandbox & Production" -->
    <key>aps-environment</key>
    <string>production</string>
    <!-- ⚠️ Universal Links désactivés temporairement le temps de configurer
         la capability dans Xcode UI (Signing & Capabilities > + Capability >
         Associated Domains). À réactiver pour le prochain build :
         <key>com.apple.developer.associated-domains</key>
         <array><string>applinks:yaram.app</string></array>
         L'AASA file public/.well-known/apple-app-site-association reste
         déployé sur le web (zéro effet tant que iOS n'a pas l'entitlement). -->
</dict>
</plist>
